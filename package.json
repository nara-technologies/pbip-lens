{
  "name": "pbip-lens",
  "displayName": "PBIP Lens",
  "description": "Visual dependency and impact analysis for Power BI Project (.pbip) files. Track DAX measures from definition to report visuals.\"",
  "version": "0.1.2",
  "publisher": "Nara-Technologies",
  "repository": {
    "type": "git",
    "url": "https://github.com/nara-technologies/pbip-lens"
  },
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dax",
        "aliases": [
          "DAX",
          "dax"
        ],
        "extensions": [
          ".dax",
          ".tmdl"
        ]
      }
    ],
    "grammars": [
      {
        "language": "dax",
        "scopeName": "source.dax",
        "path": "./syntaxes/dax.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pbip-lens-container",
          "title": "PBIP Lens",
          "icon": "images/logo.png",
          "type": "tree"
        }
      ]
    },
    "views": {
      "pbip-lens-container": [
        {
          "id": "pbipLensMeasuresView",
          "name": "Measures Explorer",
          "icon": "images/logo.png",
          "visibility": "visible",
          "showCollapseAll": true
        },
        {
          "id": "pbipLensTablesView",
          "name": "Tables Explorer",
          "icon": "images/logo.png",
          "visibility": "visible",
          "showCollapseAll": true
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pbipLensMeasuresView",
        "contents": "Escanea tu proyecto PBIP para identificar el uso de medidas DAX en visuales y detectar huérfanas.\n[Auditar Proyecto](command:pbip-lens.runAudit)\nPara más información, [lee la documentación](https://github.com/nara-technologies/pbip-lens)."
      },
      {
        "view": "pbipLensTablesView",
        "contents": "Analiza las tablas y columnas de tu modelo semántico para evaluar el impacto de cambios.\n[Auditar Proyecto](command:pbip-lens.runAudit)"
      }
    ],
    "commands": [
      {
        "command": "pbip-lens.runAudit",
        "title": "PBIP Lens: Auditar Proyecto",
        "icon": "$(play)"
      },
      {
        "command": "pbip-lens.refreshAudit",
        "title": "PBIP Lens: Refrescar Auditoría",
        "icon": "$(refresh)"
      },
      {
        "command": "pbip-lens.expandAll",
        "title": "Expandir Todo",
        "icon": "$(expand-all)"
      },
      {
        "command": "pbip-lens.toggleViewMode",
        "title": "PBIP Lens: Toggle Group By Pages",
        "icon": "$(list-flat)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pbip-lens.refreshAudit",
          "when": "view == pbipLensMeasuresView || view == pbipLensTablesView",
          "group": "navigation@1"
        },
        {
          "command": "pbip-lens.expandAll",
          "when": "view == pbipLensMeasuresView || view == pbipLensTablesView",
          "group": "navigation@2"
        },
        {
          "command": "pbip-lens.toggleViewMode",
          "when": "view == pbipLensMeasuresView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "pbip-lens.expandAll",
          "when": "view == pbipLensMeasuresView || view == pbipLensTablesView",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
