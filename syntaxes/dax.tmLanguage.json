{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DAX",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#measures"
    },
    {
      "include": "#tables"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "(//|--).*$",
          "name": "comment.line.double-slash.dax"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.dax"
        }
      ]
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.dax"
    },
    "measures": {
      "match": "\\[[^\\]]+\\]",
      "name": "variable.other.property.dax"
    },
    "tables": {
      "match": "'[^']+'",
      "name": "entity.name.type.class.dax"
    },
    "keywords": {
      "patterns": [
        {
          "match": "(?i)\\b(RETURN|VAR|IF|ELSE|SWITCH|TRUE|FALSE|BLANK)\\b",
          "name": "keyword.control.dax"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "(?i)\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "support.function.dax"
        }
      ]
    },
    "operators": {
      "match": "(&&|\\|\\||==|>=|<=|<>|>|<|=|\\+|-|\\*|/)",
      "name": "keyword.operator.dax"
    }
  },
  "scopeName": "source.dax"
}
